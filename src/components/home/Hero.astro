---
import SiteHeader from "./SiteHeader.astro";
---

<header class="hero section" aria-labelledby="hero-title">
  <picture>
    <source media="(max-width: 640px)" srcset="/assets/images/home/hero-mobile.png" />
    <source media="(max-width: 1024px)" srcset="/assets/images/home/hero-tablet.png" />
    <img
      class="hero__image"
      src="/assets/images/home/hero-desktop.webp"
      alt="Ta'i Paitai weaving in a low-lit studio."
    />
  </picture>
  <div class="hero__overlay" aria-hidden="true"></div>
  <SiteHeader />
  <div class="frame-shell hero__frame">
    <div class="hero__copy">
      <h1 id="hero-title">Ta'i Paitai</h1>
      <p>ARTIST</p>
    </div>
  </div>
</header>
